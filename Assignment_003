#include <iostream>
using namespace std;

struct book {
    int barcode;
    string title;
    int year;
    int rating;
    string category;
};


int isUnique(book b[], int size, int code) {
    for(int i = 0; i < size; i++) {
        if(b[i].barcode == code) {
            return 0; 
        }
    }
    return 1; 
}

string getCategory(int rating) {
    if(rating == 5) return "Excellent";
    else if(rating == 4) return "Very Good";
    else if(rating == 3) return "Good";
    else if(rating == 2) return "Fair";
    else if(rating == 1) return "Poor";
    else return "No Rating";
}


int input(book b[]) {
    int number;
    
    cout << "Enter number of books: ";
    cin >> number;

    for(int i = 0; i < number; i++) {
        cout << "\nBook" << i+1 << endl;

        int code;
        do {
            cout << "Enter barcode: ";
            cin >> code;

            if(!isUnique(b, i, code)) {
                cout << "Barcode already exists! Enter again.\n";
            }
        } while(!isUnique(b, i, code));

        b[i].barcode = code;

        cout << "Enter title: ";
        cin.ignore();
        getline (cin,b[i].title);
        

        cout << "Enter year: ";
        cin >> b[i].year;

        cout << "Enter rating (0-5): ";
        cin >> b[i].rating;
    }

    return number;
}


int display(book b[], int number) {
    cout << "\n\n--- BOOK LIST ---\n";
    cout << "Barcode\tTitle\t\tYear\tRating\tCategory\n";

    for(int i = 0; i < number; i++) {
        cout << b[i].barcode << "\t"
             << b[i].title << "\t"
             << b[i].year << "\t"
             << b[i].rating << "\t"
             << getCategory(b[i].rating) << endl;
    }

    return 0;
}

int main() {
    char rep;

    do {
        book obj[20]; 

        int number = input(obj);  
        display(obj, number);   

        cout << "\nRun again? (y/n): ";
        cin >> rep;

    } while(toupper(rep) == 'Y');

    return 0;
}