#include <iostream>
#include <iomanip>

using namespace std;

void processGrades(int* matrix, int rows, int cols);

int main() {
    int students, subjects;

    cout << "Enter the number of students: ";
    cin >> students;
    cout << "Enter the number of subjects: ";
    cin >> subjects;

    int grades[students][subjects];

    for (int i = 0; i < students; i++) {
        cout << "\nEnter grades for Student " << i + 1 << ":" << endl;
        for (int j = 0; j < subjects; j++) {
            cout << "  Subject " << j + 1 << ": ";
            cin >> grades[i][j];
        }
    }

    processGrades((int*)grades, students, subjects);

    return 0;
}

void processGrades(int* matrix, int rows, int cols) {
    int highestGrade = -1;

    cout << "\n--- Grade Matrix Report ---" << endl;

    for (int i = 0; i < rows; i++) {
        double sum = 0;
        cout << "Student " << i + 1 << ": ";
        
        for (int j = 0; j < cols; j++) {
            int currentGrade = *(matrix + (i * cols) + j);
            cout << setw(5) << currentGrade;

            if (currentGrade > highestGrade) {
                highestGrade = currentGrade;
            }

            sum += currentGrade;
        }

        double average = sum / cols;
        cout << " | Average: " << fixed << setprecision(2) << average << endl;
    }

    cout << "\n---------------------------" << endl;
    cout << "Highest Grade in Matrix: " << highestGrade << endl;
}